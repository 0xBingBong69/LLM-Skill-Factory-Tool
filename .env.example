# Copy this file to `.env` and fill in your values. `.env` is gitignored.

# Required: your OpenRouter API key (https://openrouter.ai/keys)
OPENROUTER_API_KEY=

# Optional: default model id used for generation (any OpenRouter model id).
# Examples: anthropic/claude-sonnet-4.6, openai/gpt-4o, x-ai/grok-2
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.6

# Optional: shown to OpenRouter for attribution / rankings.
OPENROUTER_APP_TITLE=LLM Skill Factory
OPENROUTER_APP_URL=https://github.com/0xBingBong69/LLM-Skill-Factory-Tool

# Optional: where generated skills are written (defaults to ./skills)
SKILLS_DIR=

# Optional: deferred web-research provider key (not wired in v1; reserved).
# TAVILY_API_KEY=
