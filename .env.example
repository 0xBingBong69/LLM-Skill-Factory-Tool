# Copy this file to `.env` and fill in your values. `.env` is gitignored.
# You only need a key for the provider(s) you intend to use.

# Which provider to use by default: openrouter | minimax | kimi | custom
LLM_PROVIDER=openrouter

# --- OpenRouter (https://openrouter.ai/keys) -------------------------------
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=anthropic/claude-sonnet-4.6

# --- MiniMax (https://www.minimax.io/platform) -----------------------------
MINIMAX_API_KEY=
MINIMAX_DEFAULT_MODEL=MiniMax-M3

# --- Kimi / Moonshot (https://platform.moonshot.ai/console/api-keys) -------
MOONSHOT_API_KEY=
KIMI_DEFAULT_MODEL=kimi-k2.6

# --- Custom OpenAI-compatible endpoint (optional) --------------------------
# LLM_API_KEY=
# CUSTOM_DEFAULT_MODEL=

# Optional: attribution shown to OpenRouter for rankings.
APP_TITLE=LLM Skill Factory
APP_URL=https://github.com/0xBingBong69/LLM-Skill-Factory-Tool

# Optional: where generated skills are written (defaults to ./skills)
SKILLS_DIR=

# Optional: deferred web-research provider key (not wired in v1; reserved).
# TAVILY_API_KEY=
